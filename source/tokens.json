{
  "$schema": "https://design-tokens.org/schemas/draft-2024-08/tokens.json",
  "$description": "AIDE Institute design tokens. Source of truth: ~/aide/branding/DESIGN_TOKENS.md (2026-05-22).",

  "color": {
    "core": {
      "navy": {
        "$value": "#1B2541",
        "$type": "color",
        "$description": "Dark Navy. Primary bg, wordmark, headers, footers."
      },
      "blue": {
        "$value": "#3B82F6",
        "$type": "color",
        "$description": "Logo 'Institute' text, light accent on dark."
      },
      "violet": {
        "$value": "#7C3AED",
        "$type": "color",
        "$description": "Institute Violet. Section labels, dividers, URLs, structural accents."
      },
      "fuchsia": {
        "$value": "#E600FF",
        "$type": "color",
        "$description": "CTAs, data highlights, accent bars, hero stats. Same hex as color.subbrand.index — kept distinct for semantic clarity."
      },
      "white": {
        "$value": "#FFFFFF",
        "$type": "color",
        "$description": "Page bg, text on dark."
      },
      "ink": {
        "$value": "#1A1A1A",
        "$type": "color",
        "$description": "Body text on light."
      },
      "midGray": {
        "$value": "#777777",
        "$type": "color",
        "$description": "Secondary text, captions, metadata."
      },
      "lightGray": {
        "$value": "#F8F9FB",
        "$type": "color",
        "$description": "Card fills, subtle bg, alt rows."
      }
    },

    "subbrand": {
      "$description": "Use only in that sub-brand's assets. Never mix with pillar colors.",
      "index": {
        "$value": "#E600FF",
        "$type": "color",
        "$description": "AIDE Index — Research. Same hex as color.core.fuchsia."
      },
      "insights": {
        "$value": "#5CFFC8",
        "$type": "color",
        "$description": "AIDE Insights — Publishing. Mint."
      },
      "rankings": {
        "$value": "#FF7A00",
        "$type": "color",
        "$description": "AIDE Rankings — AIDE50. Orange."
      },
      "awards": {
        "$value": "#7B2FFF",
        "$type": "color",
        "$description": "AIDE Awards. Purple."
      },
      "education": {
        "$value": "#FF47C2",
        "$type": "color",
        "$description": "AIDE Education. Pink."
      },
      "talent": {
        "$value": "#00E5A0",
        "$type": "color",
        "$description": "AIDE Talent. Teal."
      }
    },

    "pillar": {
      "$description": "Use only in AIDE Index scoring content. Never mix with sub-brand colors.",
      "literacy": {
        "$value": "#4ADE80",
        "$type": "color",
        "$description": "Literacy / KNOW. Green."
      },
      "advocacy": {
        "$value": "#A78BFA",
        "$type": "color",
        "$description": "Advocacy / SAY. Violet."
      },
      "orientation": {
        "$value": "#D946EF",
        "$type": "color",
        "$description": "Orientation / PRIORITIZE. Fuchsia-family — distinct from color.core.fuchsia #E600FF."
      },
      "implementation": {
        "$value": "#FBBF24",
        "$type": "color",
        "$description": "Implementation / BUILD. Amber."
      }
    },

    "bg": {
      "surface": {
        "$value": "{color.core.white}",
        "$type": "color",
        "$description": "Default page background."
      },
      "subtle": {
        "$value": "{color.core.lightGray}",
        "$type": "color",
        "$description": "Cards, alt rows, light panels."
      },
      "inverse": {
        "$value": "{color.core.navy}",
        "$type": "color",
        "$description": "Dark hero sections, footers, headers."
      }
    },

    "fg": {
      "primary": {
        "$value": "{color.core.ink}",
        "$type": "color",
        "$description": "Body text on light."
      },
      "secondary": {
        "$value": "{color.core.midGray}",
        "$type": "color",
        "$description": "Captions, metadata."
      },
      "onInverse": {
        "$value": "{color.core.white}",
        "$type": "color",
        "$description": "Text on navy."
      },
      "link": {
        "$value": "{color.core.violet}",
        "$type": "color",
        "$description": "URLs, navigation links."
      }
    },

    "border": {
      "subtle": {
        "$value": "rgba(0,0,0,0.06)",
        "$type": "color",
        "$description": "Card borders, swatch outlines."
      },
      "muted": {
        "$value": "#EBEBEF",
        "$type": "color",
        "$description": "1px section separators in dense layouts (welcome emails). Heavier than border.subtle for stronger visual separation at small sizes."
      },
      "divider": {
        "$value": "{color.core.violet}",
        "$type": "color",
        "$description": "Structural section dividers."
      }
    },

    "accent": {
      "cta": {
        "$value": "{color.core.fuchsia}",
        "$type": "color",
        "$description": "Primary CTAs, accent bars, hero stat highlights."
      },
      "label": {
        "$value": "{color.core.violet}",
        "$type": "color",
        "$description": "Section number labels, uppercase eyebrow labels."
      }
    }
  },

  "font": {
    "family": {
      "primary": {
        "$value": ["Camera Plain Variable", "ui-sans-serif", "system-ui", "sans-serif"],
        "$type": "fontFamily",
        "$description": "The only typeface used in AIDE materials."
      },
      "mono": {
        "$value": ["SF Mono", "Fira Code", "monospace"],
        "$type": "fontFamily",
        "$description": "Hex codes, file paths, inline code only."
      }
    },
    "weight": {
      "regular": {
        "$value": 400,
        "$type": "fontWeight"
      },
      "bold": {
        "$value": 700,
        "$type": "fontWeight"
      },
      "black": {
        "$value": 900,
        "$type": "fontWeight"
      }
    }
  },

  "text": {
    "$description": "Typography composites. Sizes default to the value most used in AIDE_Brand_Guidelines.html; the source range is documented in DESIGN_TOKENS.md.",
    "display": {
      "$type": "typography",
      "$value": {
        "fontFamily": "{font.family.primary}",
        "fontSize": "36px",
        "fontWeight": "{font.weight.black}",
        "lineHeight": "1.1",
        "letterSpacing": "-0.5px"
      },
      "$description": "Hero headings, cover titles, report titles. Range 36–48px."
    },
    "heading": {
      "$type": "typography",
      "$value": {
        "fontFamily": "{font.family.primary}",
        "fontSize": "28px",
        "fontWeight": "{font.weight.black}",
        "lineHeight": "1.2",
        "letterSpacing": "-0.3px"
      },
      "$description": "Section headings, card titles. Range 22–28px."
    },
    "subheading": {
      "$type": "typography",
      "$value": {
        "fontFamily": "{font.family.primary}",
        "fontSize": "18px",
        "fontWeight": "{font.weight.bold}",
        "lineHeight": "1.4",
        "letterSpacing": "0px"
      },
      "$description": "Sub-section titles, table headers. Range 16–18px."
    },
    "body": {
      "$type": "typography",
      "$value": {
        "fontFamily": "{font.family.primary}",
        "fontSize": "15px",
        "fontWeight": "{font.weight.regular}",
        "lineHeight": "1.7",
        "letterSpacing": "0px"
      },
      "$description": "Paragraphs, descriptions. Range 14–16px. Line height 1.6–1.7."
    },
    "caption": {
      "$type": "typography",
      "$value": {
        "fontFamily": "{font.family.primary}",
        "fontSize": "12px",
        "fontWeight": "{font.weight.regular}",
        "lineHeight": "1.5",
        "letterSpacing": "0px"
      },
      "$description": "Source lines, captions, metadata. Range 11–13px. Color: color.fg.secondary."
    },
    "label": {
      "$type": "typography",
      "$value": {
        "fontFamily": "{font.family.primary}",
        "fontSize": "12px",
        "fontWeight": "{font.weight.bold}",
        "lineHeight": "1.2",
        "letterSpacing": "1.5px",
        "textCase": "uppercase"
      },
      "$description": "Eyebrow labels, section nums, table headers. Range 11–14px, letter-spacing 1–2px. Color: color.accent.label."
    },
    "mono": {
      "$type": "typography",
      "$value": {
        "fontFamily": "{font.family.mono}",
        "fontSize": "12px",
        "fontWeight": "{font.weight.regular}",
        "lineHeight": "1.4",
        "letterSpacing": "0px"
      },
      "$description": "Hex codes, file paths. Range 11–12px."
    }
  },

  "space": {
    "$description": "4px-based scale derived from observed margins in AIDE_Brand_Guidelines.html.",
    "0":  { "$value": "0px",   "$type": "dimension" },
    "1":  { "$value": "4px",   "$type": "dimension" },
    "2":  { "$value": "8px",   "$type": "dimension" },
    "3":  { "$value": "12px",  "$type": "dimension" },
    "4":  { "$value": "16px",  "$type": "dimension" },
    "5":  { "$value": "20px",  "$type": "dimension" },
    "6":  { "$value": "24px",  "$type": "dimension" },
    "8":  { "$value": "32px",  "$type": "dimension" },
    "10": { "$value": "40px",  "$type": "dimension" },
    "12": { "$value": "48px",  "$type": "dimension" },
    "16": { "$value": "60px",  "$type": "dimension" },
    "20": { "$value": "80px",  "$type": "dimension" },
    "24": { "$value": "100px", "$type": "dimension" }
  },

  "radius": {
    "sm":  { "$value": "4px",  "$type": "dimension", "$description": "Inline code, small chips." },
    "md":  { "$value": "6px",  "$type": "dimension", "$description": "Color swatches." },
    "lg":  { "$value": "8px",  "$type": "dimension", "$description": "Usage example rows, divider bars." },
    "xl":  { "$value": "10px", "$type": "dimension", "$description": "Code blocks, preview cards." },
    "2xl": { "$value": "12px", "$type": "dimension", "$description": "Cards, panels, callouts." }
  },

  "_omitted": {
    "$description": "Intentionally absent from v1, per DESIGN_TOKENS.md. Do not synthesize.",
    "shadow": "The brand explicitly uses no shadows on the logo. Guidelines doc has no box-shadows. Use borders + color contrast for elevation.",
    "motion": "No motion values documented. Only a 0.2s color transition on TOC link hover exists in the guidelines doc. Defer.",
    "tagBackgrounds": "Skill defined TEAL_LT / PURP_LT but they are not used in any shipped asset. Add consciously in a v1.1 pillar extension if methodology graphics need them.",
    "componentSizing": "Button heights, input padding, etc. — defer to component inventory pass.",
    "darkMode": "Brand has dark surfaces (color.bg.inverse) used inline; a full dark-theme alias map is not warranted yet.",
    "iconography": "No icon family documented in any source."
  }
}
